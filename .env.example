# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Where submissions are delivered (overrides NEXT_PUBLIC_CONTACT_EMAIL and code default inbox).
# With the default sender (onboarding@resend.dev), Resend ONLY allows your Resend account email here.
# Example: if you signed up with you@gmail.com, set CONTACT_TO_EMAIL=you@gmail.com
# To use your school/work address: verify a domain at https://resend.com/domains then set CONTACT_FROM.

CONTACT_TO_EMAIL=your-resend-signup-email@example.com

# Optional. After domain verification:
# CONTACT_FROM=Micah Mei <hello@yourdomain.com>

# Footer icons (full URLs). Shown only when set.
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/yourusername
# NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
# NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
